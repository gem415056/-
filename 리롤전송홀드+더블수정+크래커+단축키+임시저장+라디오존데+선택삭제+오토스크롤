    function initRPToolbar() {
        const fixedTools = [
            { icon: '★', pre: '*', suf: '*' },
            { icon: '♠', pre: '"', suf: '"' },
            { icon: '♤', pre: "'", suf: "'" },
            { icon: '◆', pre: '`', suf: '`' },
            { icon: '■', pre: '[', suf: ']' },
            { icon: '♣', pre: '(!', suf: ')' },
            { icon: '♧', pre: '(OOC：', suf: ')' }
        ];

        if (!document.getElementById('hide-native-rp-btns')) {
            const style = document.createElement('style');
            style.id = 'hide-native-rp-btns';
            style.textContent = `
                .igx-rp-container-hooked > button:not(.igx-keep-btn) {
                    display: none !important;
                }
            `;
            document.head.appendChild(style);
        }

        function wrapText(prefix, suffix) {
            const textarea = document.querySelector('textarea');
            if (!textarea) return;

            const start = textarea.selectionStart || 0;
            const end = textarea.selectionEnd || 0;
            const text = textarea.value || '';
            const selected = text.substring(start, end);
            const before = text.substring(0, start);
            const after = text.substring(end, text.length);

            const newValue = before + prefix + selected + suffix + after;

            const nativeInputValueSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, "value").set;
            nativeInputValueSetter.call(textarea, newValue);
            textarea.dispatchEvent(new Event('input', { bubbles: true }));

            textarea.focus();
            textarea.setSelectionRange(start + prefix.length, end + prefix.length);
        }

        function createToolButton(iconText, onClick) {
            const btn = document.createElement('button');
            btn.className = "relative inline-flex items-center gap-1 rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7 justify-center";
            btn.type = "button";
            btn.innerHTML = `<span style="font-size:15px;">${iconText}</span>`;

            btn.onmousedown = (e) => e.preventDefault();
            btn.onclick = (e) => {
                e.preventDefault();
                onClick();
            };
            return btn;
        }

        document.addEventListener('keydown', (e) => {
            if (!e.altKey) return;
            let idx = -1;
            const code = e.code;
            const key = e.key;

            if (code === 'Backquote' || key === '`' || key === '~') idx = 0;
            else if (code === 'Digit1' || key === '1') idx = 1;
            else if (code === 'Digit2' || key === '2') idx = 2;
            else if (code === 'Digit3' || key === '3') idx = 3;
            else if (code === 'Digit4' || key === '4') idx = 4;
            else if (code === 'Digit5' || key === '5') idx = 5;
            else if (code === 'Digit6' || key === '6') idx = 6;

            if (idx !== -1) {
                const textarea = document.querySelector('textarea');
                if (document.activeElement === textarea) {
                    if (fixedTools[idx]) {
                        e.preventDefault();
                        e.stopPropagation();
                        wrapText(fixedTools[idx].pre, fixedTools[idx].suf);
                    }
                }
            }
        }, true);

        setInterval(() => {
            const btnContainer = document.querySelector('.flex.items-center.space-x-2');
            if (!btnContainer) return;

            if (!btnContainer.classList.contains('igx-rp-container-hooked')) {
                btnContainer.classList.add('igx-rp-container-hooked');
            }

            const recommendBtn = Array.from(btnContainer.querySelectorAll('button')).find(btn => btn.textContent.includes('추천답변'));
            if (recommendBtn && !recommendBtn.classList.contains('igx-keep-btn')) {
                recommendBtn.classList.add('igx-keep-btn');
            }

            if (!document.getElementById('custom-rp-tools')) {
                const toolWrapper = document.createElement('div');
                toolWrapper.id = 'custom-rp-tools';
                // [수정됨] 우측 여백 강제 값을 빼고, 원래대로 복원하여 우측 전송버튼부와 대칭 간격 조화
                toolWrapper.className = 'flex items-center space-x-1 ml-1 mr-1';

                // 1. 선택삭제 버튼 껍데기 (텍스트 아이콘화)
                const selectDeleteBtn = document.createElement('button');
                selectDeleteBtn.id = 'tm-message-delete-mode-btn';
                selectDeleteBtn.className = "relative inline-flex items-center gap-1 rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7 justify-center";
                selectDeleteBtn.innerHTML = `<span style="font-size:15px;">□</span>`;
                toolWrapper.appendChild(selectDeleteBtn);

                // 2. 오토스크롤 버튼 껍데기 (텍스트 아이콘화)
                const autoScrollBtn = document.createElement('button');
                autoScrollBtn.id = 'turbo-scroll-btn';
                autoScrollBtn.className = "relative inline-flex items-center gap-1 rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7 justify-center";
                autoScrollBtn.innerHTML = `<span style="font-size:15px;">△</span>`;
                toolWrapper.appendChild(autoScrollBtn);

                // [수정됨] 3. 오토스크롤과 ★ 사이에 1.5배 간격과 세로 회색 점선 넣기
                const divider = document.createElement('div');
                divider.style.width = '1px';
                divider.style.height = '14px';
                divider.style.borderRight = '2px dotted currentColor';
                divider.style.opacity = '0.3';
                divider.style.margin = '0 6px 0 2px'; 
                toolWrapper.appendChild(divider);

                // 4. 기존 커스텀 툴바 버튼 추가
                fixedTools.forEach((t) => {
                    const btn = createToolButton(t.icon, () => wrapText(t.pre, t.suf));
                    toolWrapper.appendChild(btn);
                });

                if (recommendBtn) {
                    btnContainer.insertBefore(toolWrapper, recommendBtn);
                } else {
                    btnContainer.appendChild(toolWrapper);
                }
            }
        }, 500);
    }

