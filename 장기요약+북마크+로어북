                    window.scrollTo(0, 0); document.querySelectorAll('div').forEach(div => { if (div.scrollHeight > div.clientHeight) div.scrollTop = 0; });
                }
            }, 800);
        }

        injectStyles();
        setTimeout(applyHighlightsToDOM, 1000);
        
        const targetId = localStorage.getItem('cbm_jump_target');
