                .cbm-search:focus { outline: 1px solid ${ACCENT_COLOR}; }
                #cbm-toggle-move, #cbm-toggle-del { display: flex; align-items: center; justify-content: center; font-size: 18px; border: 1px solid #ddd; border-radius: 8px; min-height: 36px; padding: 0 12px; cursor: pointer; background: #fff;}
                #cbm-toggle-move.active { background: ${ACCENT_COLOR}; color: white; border-color: ${ACCENT_COLOR}; }
                #cbm-toggle-del.active { background: ${DELETE_COLOR}; color: white; border-color: ${DELETE_COLOR}; }
                
                #cbm-move-actions { display: none; justify-content: space-between; align-items: center; margin-bottom: 12px; background: rgba(251,167,7,0.08); padding: 0 12px; border-radius: 8px; border: 1px solid rgba(251,167,7,0.3); min-height: 36px; box-sizing: border-box; }
                #cbm-move-count { color: ${ACCENT_COLOR}; font-weight: bold; font-size: 13px; margin-top: 1px; }
                #cbm-move-select-all { background: none; border: none; cursor: pointer; font-size: 16px; padding: 0; margin-right: 6px; color: ${ACCENT_COLOR}; display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; }
                #cbm-move-folder-select { border: 1px solid #ddd; border-radius: 4px; font-size: 12px; padding: 3px 6px; background: #fff; color: #333; height: 24px; }
                
                #cbm-delete-actions { display: none; justify-content: space-between; align-items: center; margin-bottom: 12px; background: rgba(255,68,51,0.08); padding: 0 12px; border-radius: 8px; border: 1px solid rgba(255,68,51,0.3); min-height: 36px; box-sizing: border-box; }
                #cbm-del-count { color: ${DELETE_COLOR}; font-weight: bold; font-size: 13px; margin-top: 1px; }
                #cbm-del-select-all { background: none; border: none; cursor: pointer; font-size: 16px; padding: 0; margin-right: 6px; color: ${DELETE_COLOR}; display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; }
                
                .cbm-action-btn-sm { font-size: 12px; padding: 0 10px; border-radius: 4px; border: none; cursor: pointer; height: 24px; color: white; display: inline-flex; align-items: center; justify-content: center; font-weight: bold; }
                .cbm-list { flex: 1; overflow-y: auto; padding-right: 4px; }
                .cbm-item { background: #f9f9f9 !important; border: 1px solid #eee !important; border-radius: 8px; padding: 12px; margin-bottom: 10px; cursor: pointer; transition: 0.2s; position: relative; }
                .cbm-item:hover { border-color: ${ACCENT_COLOR} !important; }
                .cbm-item.selected-move { border-color: ${ACCENT_COLOR} !important; background: rgba(251,167,7,0.05) !important; }
                .cbm-item.selected-delete { border-color: ${DELETE_COLOR} !important; background: rgba(255,68,51,0.05) !important; }
                .cbm-item-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
                .cbm-item-title { font-weight: 700; font-size: 13px; display: flex; align-items: center; gap: 6px; color: #333 !important;}
                .cbm-item-color { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
                .cbm-item-edit { background: none; border: none; font-size: 14px; cursor: pointer; color: #888; padding: 0 4px; }
                .cbm-item-edit:hover { color: ${ACCENT_COLOR}; }
                .cbm-item-folder-tag { font-size: 11px; color: #555; background: #eee; padding: 2px 6px; border-radius: 4px; white-space: nowrap; max-width: 90px; overflow: hidden; text-overflow: ellipsis; }
                .cbm-item-text { font-size: 12px; color: #666 !important; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; margin-top: 8px; }
                .cbm-empty { text-align: center; color: #999; margin-top: 40px; font-size: 13px; line-height: 1.6; }
                
                body[data-theme="dark"] .crack-bm-modal { background: #242321 !important; color: #F0EFEB !important; }
                body[data-theme="dark"] .cbm-header h3 { color: #F0EFEB !important; }
                body[data-theme="dark"] .cbm-icon-btn { color: #aaa; }
                body[data-theme="dark"] .cbm-icon-btn:hover { background: #333; color: #fff; }
                body[data-theme="dark"] .cbm-tabs-container { border-bottom-color: #444; }
                body[data-theme="dark"] .cbm-pal-btn.active { border-color: #fff; }
                body[data-theme="dark"] .cbm-ftab { background: #141413; border-color: #42413D; color: #ccc; }
                body[data-theme="dark"] .cbm-ftab.active { background: ${ACCENT_COLOR}; color: #fff; border-color: ${ACCENT_COLOR}; }
                body[data-theme="dark"] .cbm-search { background: #141413 !important; border-color: #42413D !important; color: #F0EFEB !important; }
                body[data-theme="dark"] #cbm-toggle-move, body[data-theme="dark"] #cbm-toggle-del { background: #141413; border-color: #42413D; color: #ccc; }
                body[data-theme="dark"] #cbm-toggle-move.active { background: ${ACCENT_COLOR}; color: white; border-color: ${ACCENT_COLOR}; }
                body[data-theme="dark"] #cbm-toggle-del.active { background: ${DELETE_COLOR}; color: white; border-color: ${DELETE_COLOR}; }
                body[data-theme="dark"] .cbm-item { background: #1a1918 !important; border-color: #42413D !important; }
                body[data-theme="dark"] .cbm-item.selected-move { background: rgba(251,167,7,0.15) !important; border-color: ${ACCENT_COLOR} !important; }
                body[data-theme="dark"] .cbm-item.selected-delete { background: rgba(255,68,51,0.15) !important; border-color: ${DELETE_COLOR} !important; }
                body[data-theme="dark"] .cbm-item-title { color: #F0EFEB !important; }
                body[data-theme="dark"] .cbm-item-text { color: #aaa !important; }
                body[data-theme="dark"] .cbm-item-folder-tag { background: #333; color: #ccc; }
                body[data-theme="dark"] #cbm-move-folder-select { background: #141413; border-color: #42413D; color: #ccc;}
            `;
            document.head.appendChild(s);
        }

        function hexToRgba(hex, alpha = 0.4) {
            let r = parseInt(hex.slice(1, 3), 16), g = parseInt(hex.slice(3, 5), 16), b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
        }
        function hexToRgb(hex) {
            let r = parseInt(hex.slice(1, 3), 16), g = parseInt(hex.slice(3, 5), 16), b = parseInt(hex.slice(5, 7), 16);
            return `rgb(${r}, ${g}, ${b})`;
        }
        function escapeHtml(s) {
            if (!s) return "";
            return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function injectHeaderButton() {
            const headerContainer = document.querySelector('.absolute.z-\\[5\\] .flex.gap-3.items-center');
            if (!headerContainer || headerContainer.querySelector('.crack-ext-header-bm-btn')) return;
            
            const btn = document.createElement('button');
            btn.className = 'crack-ext-header-bm-btn';
            btn.innerHTML = `💡 북마크`;
            btn.style.marginRight = '-6px'; 
            
            btn.onclick = (e) => { 
                e.preventDefault(); e.stopPropagation(); 
                savedSelectionText = realtimeSelectionText;
                openModal(); 
            };
            
            headerContainer.prepend(btn);
        }

        function addBookmarkDirect(text, colorHex) {
            if (!text) return;
            const cid = getChatId();
            const sid = getStoryId();
            if (!cid) return alert("대화방 ID를 찾을 수 없습니다.");

            let bms = getBookmarks();
            bms.push({
                id: 'bm_' + Date.now(),
                chatId: cid, storyId: sid, text: text, color: colorHex,
                label: '새 북마크', folderId: 'default', timestamp: Date.now()
            });
            saveBookmarks(bms);
        }

        function openModal() {
            if (document.getElementById('cbm-overlay')) return;
            isModalOpen = true;
            isDeleteMode = false; selectedForDelete.clear();
            isMoveMode = false; selectedForMove.clear();
            
            const overlay = document.createElement('div');
            overlay.id = 'cbm-overlay';
            overlay.className = 'crack-bm-overlay';
            
            overlay.innerHTML = `
                <div class="crack-bm-modal">
                    <div class="cbm-header">
                        <h3>💡 기억해야할 순간들</h3>
                        <div class="cbm-header-btns">
                            <button class="cbm-icon-btn" id="cbm-export" title="백업 내보내기">▼</button>
                            <button class="cbm-icon-btn" id="cbm-import" title="백업 가져오기">▲</button>
                            <button class="cbm-icon-btn" id="cbm-close">✕</button>
                        </div>
                    </div>
                    <div class="cbm-tabs-container">
                        <div class="cbm-tabs">
                            <button class="cbm-tab active" data-tab="current">현재 대화</button>
                            <button class="cbm-tab" data-tab="all">전체 보기</button>
                        </div>
                        <div class="cbm-color-palette" id="cbm-color-palette"></div>
                    </div>
                    <div class="cbm-folders" id="cbm-folders-container"></div>
                    
                    <div class="cbm-search-row">
                        <input type="text" class="cbm-search" id="cbm-search-input" placeholder="북마크 이름/내용 검색...">
                        <button id="cbm-toggle-move" title="다중 이동 모드">☞</button>
                        <button id="cbm-toggle-del" title="다중 삭제 모드">☜</button>
                    </div>

                    <div id="cbm-move-actions">
                        <div style="display:flex; align-items:center;">
                            <button id="cbm-move-select-all" title="현재 목록 전체 선택">□</button>
                            <span id="cbm-move-count">0개 선택됨</span>
                        </div>
                        <div style="display:flex; gap:8px; align-items:center;">
                            <select id="cbm-move-folder-select"></select>
                            <button id="cbm-move-confirm" class="cbm-action-btn-sm" style="background:${ACCENT_COLOR};" title="이동">✔</button>
                            <button id="cbm-move-cancel" class="cbm-action-btn-sm" style="background:#888;" title="취소">✘</button>
                        </div>
                    </div>
                    
                    <div id="cbm-delete-actions">
                        <div style="display:flex; align-items:center;">
                            <button id="cbm-del-select-all" title="현재 목록 전체 선택">□</button>
                            <span id="cbm-del-count">0개 선택됨</span>
                        </div>
                        <div style="display:flex; gap:8px;">
                            <button id="cbm-del-confirm" class="cbm-action-btn-sm" style="background:${DELETE_COLOR};" title="삭제">✔</button>
                            <button id="cbm-del-cancel" class="cbm-action-btn-sm" style="background:#888;" title="취소">✘</button>
                        </div>
                    </div>
                    
                    <div class="cbm-list" id="cbm-list-container"></div>
                </div>
            `;
            document.body.appendChild(overlay);

            document.getElementById('cbm-close').onclick = closeModal;
            overlay.onclick = (e) => { if(e.target === overlay) closeModal(); };
            
            const tabs = overlay.querySelectorAll('.cbm-tab');
            tabs.forEach(tab => {
                tab.onclick = () => {
                    tabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    currentTab = tab.dataset.tab;
                    searchQuery = ''; document.getElementById('cbm-search-input').value = '';
                    if(isDeleteMode) selectedForDelete.clear();
                    if(isMoveMode) selectedForMove.clear();
                    renderBookmarkList();
                };
            });

            document.getElementById('cbm-search-input').oninput = (e) => {
                searchQuery = e.target.value.trim().toLowerCase(); 
                if(isDeleteMode) selectedForDelete.clear();
                if(isMoveMode) selectedForMove.clear();
                renderBookmarkList();
            };

            // --- 다중 모드 토글 버튼들 ---
            document.getElementById('cbm-toggle-move').onclick = () => {
                isMoveMode = !isMoveMode;
                isDeleteMode = false;
                selectedForMove.clear(); selectedForDelete.clear();
                document.getElementById('cbm-toggle-move').classList.toggle('active', isMoveMode);
                document.getElementById('cbm-toggle-del').classList.remove('active');
                renderBookmarkList();
            };
            document.getElementById('cbm-toggle-del').onclick = () => {
                isDeleteMode = !isDeleteMode;
                isMoveMode = false;
                selectedForDelete.clear(); selectedForMove.clear();
                document.getElementById('cbm-toggle-del').classList.toggle('active', isDeleteMode);
                document.getElementById('cbm-toggle-move').classList.remove('active');
                renderBookmarkList();
            };

            // --- 이동 모드 액션 ---
            document.getElementById('cbm-move-select-all').onclick = () => {
                if (currentFilteredBms.length === 0) return;
                if (selectedForMove.size === currentFilteredBms.length) selectedForMove.clear();
                else currentFilteredBms.forEach(b => selectedForMove.add(b.id)); 
                renderBookmarkList();
            };
            document.getElementById('cbm-move-cancel').onclick = () => {
                isMoveMode = false; selectedForMove.clear();
                document.getElementById('cbm-toggle-move').classList.remove('active');
                renderBookmarkList();
            };
            document.getElementById('cbm-move-confirm').onclick = () => {
                const destFolderId = document.getElementById('cbm-move-folder-select').value;
                if (!destFolderId) return alert("이동할 폴더를 선택해주세요.");
                if (selectedForMove.size === 0) return alert("이동할 항목을 선택해주세요.");
                
                let bms = getBookmarks();
                bms.forEach(b => { if (selectedForMove.has(b.id)) b.folderId = destFolderId; });
                saveBookmarks(bms);
                
                isMoveMode = false; selectedForMove.clear();
                document.getElementById('cbm-toggle-move').classList.remove('active');
                renderBookmarkList();
            };

            // --- 삭제 모드 액션 ---
            document.getElementById('cbm-del-select-all').onclick = () => {
                if (currentFilteredBms.length === 0) return;
                if (selectedForDelete.size === currentFilteredBms.length) selectedForDelete.clear();
                else currentFilteredBms.forEach(b => selectedForDelete.add(b.id)); 
                renderBookmarkList();
            };
            document.getElementById('cbm-del-cancel').onclick = () => {
                isDeleteMode = false; selectedForDelete.clear();
                document.getElementById('cbm-toggle-del').classList.remove('active');
                renderBookmarkList();
            };
            document.getElementById('cbm-del-confirm').onclick = () => {
                if (selectedForDelete.size === 0) return alert("삭제할 항목을 선택해주세요.");
                if (!confirm(`선택한 ${selectedForDelete.size}개의 북마크를 삭제하시겠습니까?`)) return;
                
                let bms = getBookmarks().filter(b => !selectedForDelete.has(b.id));
                saveBookmarks(bms);
                
                selectedForDelete.forEach(id => {
                    document.querySelectorAll(`mark[data-bm-id="${id}"]`).forEach(m => {
                        m.parentNode.replaceChild(document.createTextNode(m.textContent), m);
                    });
                });
                
                isDeleteMode = false; selectedForDelete.clear();
                document.getElementById('cbm-toggle-del').classList.remove('active');
                renderBookmarkList();
            };

            const paletteContainer = document.getElementById('cbm-color-palette');
            FIX_COLORS.forEach(color => {
                const btn = document.createElement('div');
                btn.className = 'cbm-pal-btn';
                btn.style.backgroundColor = color;
                
                btn.onclick = () => {
                    if (savedSelectionText) {
                        addBookmarkDirect(savedSelectionText, color);
                        savedSelectionText = ""; 
                        window.getSelection().removeAllRanges();
                        renderBookmarkList();
                    } else {
                        if (activeColorFilter === color) activeColorFilter = null;
                        else activeColorFilter = color;
                        updatePaletteUI();
                        if(isDeleteMode) selectedForDelete.clear();
                        if(isMoveMode) selectedForMove.clear();
                        renderBookmarkList();
                    }
                };
