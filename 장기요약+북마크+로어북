        function applyHighlightsToDOM() {
            const bms = getBookmarks().filter(b => b.chatId === getChatId());
            if (bms.length === 0) return;

            bms.forEach(hl => {
                if (document.querySelector(`mark[data-bm-id="${hl.id}"]`)) return;

                const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
                const textNodes = []; let node;
                while (node = walker.nextNode()) {
                    const parent = node.parentNode;
                    if (!parent || ['SCRIPT', 'STYLE', 'TEXTAREA', 'INPUT', 'NOSCRIPT'].includes(parent.nodeName)) continue;
                    if (parent.closest('.crack-bm-overlay')) continue;
                    if (node.nodeValue.trim().length > 0) textNodes.push(node);
                }

                const targetText = hl.text.replace(/\s+/g, '');
                if (!targetText) return;

                let globalText = ""; const map = [];
                textNodes.forEach(n => {
                    const clean = n.nodeValue.replace(/\s+/g, '');
                    if (clean.length > 0) { map.push({ node: n, start: globalText.length, end: globalText.length + clean.length, originalText: n.nodeValue }); globalText += clean; }
                });

                let matches = []; let idx = globalText.indexOf(targetText);
                while (idx !== -1) { matches.push(idx); idx = globalText.indexOf(targetText, idx + 1); }

                matches.reverse().forEach(matchIdx => {
                    let matchEnd = matchIdx + targetText.length;
                    const overlappingNodes = map.filter(m => m.end > matchIdx && m.start < matchEnd);
                    
                    overlappingNodes.reverse().forEach(m => {
                        const nodeStartInMatch = Math.max(0, matchIdx - m.start), nodeEndInMatch = Math.min(m.end - m.start, matchEnd - m.start);
                        const getOrigIndex = (cleanIdx, origStr) => {
                            let cCount = 0;
                            for (let i = 0; i < origStr.length; i++) {
                                if (!/\s/.test(origStr[i])) { if (cCount === cleanIdx) return i; cCount++; }
                            }
                            return origStr.length;
                        };
                        const origStart = getOrigIndex(nodeStartInMatch, m.originalText), origEnd = getOrigIndex(nodeEndInMatch, m.originalText);

                        if (origStart < origEnd) {
                            const mark = document.createElement('mark');
                            mark.className = 'crack-bm-hl'; mark.style.backgroundColor = hexToRgba(hl.color, 0.45); 
                            mark.dataset.bmId = hl.id; mark.textContent = m.originalText.substring(origStart, origEnd);
                            const split1 = m.node.splitText(origStart);
                            split1.nodeValue = split1.nodeValue.substring(origEnd - origStart);
                            split1.parentNode.insertBefore(mark, split1);
                        }
                    });
                });
            });
        }

        function jumpToHighlight(id, targetChatId, targetStoryId) {
