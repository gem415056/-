        function incTurnCount(chatId) { const t = getTurnCount(chatId) + 1; localStorage.setItem(`Crack_KW_Turn_${chatId}`, String(t)); return t; }
        function getHolds(chatId) { try { return JSON.parse(localStorage.getItem(`Crack_KW_Holds_${chatId}`) || '{}'); } catch (e) { return {}; } }
