// ==/UserScript==

(function () {
    'use strict';

    // 공통 버튼 스타일 CSS
    const BTN_GRADIENT = "linear-gradient(135deg, #fba707, #ff6b6b) !important";

    // ==========================================
    // 모듈 1: 크랙 드래그 북마크 & 형광펜
    // ==========================================
    function initBookmarkSystem() {
        const FIX_COLORS = ['#F6E19A', '#F2C0C3', '#BCD0D8', '#D5C2DE'];
        const ACCENT_COLOR = '#FBA707';
        const DELETE_COLOR = '#FF4433';
        const ICON_EDIT = '✎';

        let currentPath = window.location.pathname;
        let realtimeSelectionText = "";
        let savedSelectionText = "";
        
        let isModalOpen = false;
        let currentTab = 'current';
        let currentFolderId = 'default';
        let searchQuery = '';
        let activeColorFilter = null;
        let currentFilteredBms = [];
        
        let isDeleteMode = false;
        let selectedForDelete = new Set();
        let isMoveMode = false;
        let selectedForMove = new Set();

        document.addEventListener('selectionchange', () => {
            const text = window.getSelection().toString().trim();
            realtimeSelectionText = text ? (text.includes('\n') ? text.split('\n')[0].trim() : text) : "";
        });

        const getBookmarks = () => { try { return JSON.parse(localStorage.getItem('Crack_BM_Data')) || []; } catch { return []; } };
        const saveBookmarks = (bms) => {
            localStorage.setItem('Crack_BM_Data', JSON.stringify(bms));
            applyHighlightsToDOM();
            if (isModalOpen) renderBookmarkList();
        };
        const getFolders = () => {
            try { 
                let f = JSON.parse(localStorage.getItem('Crack_BM_Folders')); 
                if (!f || !Array.isArray(f) || f.length === 0) return [{ id: 'default', name: '기본' }];
                return f;
            } catch { return [{ id: 'default', name: '기본' }]; }
        };
        const saveFolders = (folders) => {
            localStorage.setItem('Crack_BM_Folders', JSON.stringify(folders));
            if (isModalOpen) { renderFolderTabs(); renderBookmarkList(); }
        };

        function getChatId() {
            let m = location.pathname.match(/\/episodes\/([a-f0-9]+)/);
            if (m) return m[1]; m = location.pathname.match(/\/chat\/([a-f0-9]+)/); return m ? m[1] : null;
        }
        function getStoryId() {
            let m = location.pathname.match(/\/stories\/([a-f0-9]+)/); return m ? m[1] : null;
        }
        function toUrl(sid, cid) {
            return (sid && cid) ? `/stories/${sid}/episodes/${cid}` : (cid ? `/chat/${cid}` : null);
        }

        function injectStyles() {
            if (document.getElementById('crack-bm-css')) return;
            const s = document.createElement('style');
            s.id = 'crack-bm-css';
            s.textContent = `
                .crack-ext-header-bm-btn { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 6px; background: ${BTN_GRADIENT}; color: white !important; font-size: 16px; border: none !important; cursor: pointer; transition: transform 0.1s; margin-right: 4px; }
                .crack-ext-header-bm-btn:hover { filter: brightness(0.9); }
                mark.crack-bm-hl { color: inherit; border-radius: 3px; padding: 2px 0; transition: background-color 0.3s; cursor: pointer; }
                mark.crack-bm-hl:hover { filter: brightness(0.9); }
                mark.crack-bm-hl.flash { animation: bmFlash 1.5s ease; }
                @keyframes bmFlash { 0%, 100% { transform: scale(1); } 50% { background-color: ${ACCENT_COLOR} !important; color: white !important; transform: scale(1.05); box-shadow: 0 0 10px rgba(251,167,7,0.5); } }
                .crack-bm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 100000; display: flex; align-items: center; justify-content: center; pointer-events: auto !important; }
                .crack-bm-modal { background: #fff !important; border-radius: 16px; padding: 28px; width: 600px; max-width: 90vw; height: calc(66vh - 20px); max-height: calc(66vh - 20px); display: flex; flex-direction: column; box-shadow: 0 8px 40px rgba(0,0,0,0.2); pointer-events: auto !important; color: #222 !important; box-sizing: border-box; }
