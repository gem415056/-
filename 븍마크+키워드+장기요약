                .cbm-header h3 { margin: 0; font-size: 17px; font-weight: 700; color: #222 !important; display: flex; align-items: center; gap: 6px; }
                .cbm-header-btns { display: flex; gap: 8px; }
                .cbm-icon-btn { background: none; border: none; font-size: 14px; cursor: pointer; padding: 4px 8px; border-radius: 6px; color: #666; transition: 0.2s; font-weight: bold; }
                .cbm-icon-btn:hover { background: #eee; color: #222; }
                .cbm-tabs-container { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 12px; margin-bottom: 12px; }
                .cbm-tabs { display: flex; gap: 12px; margin-bottom: -13px; }
